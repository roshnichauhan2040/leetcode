class Solution {
    public int uniqueXorTriplets(int[] nums) {
        int mx = 0;
        for (int x : nums) {
            mx = Math.max(mx, x);
        }

        mx <<= 1; // Maximum possible XOR value

        boolean[] pairXor = new boolean[mx];

        // Store all possible XORs of two elements
        for (int a : nums) {
            for (int b : nums) {
                pairXor[a ^ b] = true;
            }
        }

        boolean[] result = new boolean[mx];

        // XOR each pair XOR with every element
        for (int xor = 0; xor < mx; xor++) {
            if (pairXor[xor]) {
                for (int c : nums) {
                    result[xor ^ c] = true;
                }
            }
        }

        int ans = 0;
        for (boolean x : result) {
            if (x) ans++;
        }

        return ans;
    }
}
